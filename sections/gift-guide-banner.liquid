{%- comment -%} Jost is the design font; loaded with swap so text renders immediately on the theme font. {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500&display=swap" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500&display=swap"></noscript>

{{ 'gift-guide-banner.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Gift Guide Banner (Figma Frame 1957)
  Standalone, mobile-first hero banner. All copy, links and illustrations are
  merchant-editable via the schema below. Desktop and mobile differ in layout
  AND copy (heading size, description text, strip text) — handled with paired
  settings + CSS display toggles rather than JS.
{%- endcomment -%}

{%- liquid
  assign top_art = section.settings.hero_image_top
  assign bottom_art = section.settings.hero_image_bottom
  assign mobile_art = section.settings.hero_image_mobile
-%}

<section
  class="gift-banner"
  id="gift-banner-{{ section.id }}"
  aria-label="{{ section.settings.heading | default: 'Gift Guide' | escape }}"
>
  {%- comment -%} ---------- Top bar / mobile header ---------- {%- endcomment -%}
  <div class="gift-banner__bar">
    {%- if section.settings.show_hamburger -%}
      <button type="button" class="gift-banner__hamburger" aria-label="{{ 'sections.header.menu' | t | default: 'Menu' }}">
        <svg viewBox="0 0 18 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <line x1="0" y1="1" x2="18" y2="1" stroke="currentColor" stroke-width="1.5" />
          <line x1="0" y1="9" x2="18" y2="9" stroke="currentColor" stroke-width="1.5" />
        </svg>
      </button>
    {%- endif -%}

    <span class="gift-banner__logo" role="img" aria-label="{{ section.settings.logo_text | escape }}">
