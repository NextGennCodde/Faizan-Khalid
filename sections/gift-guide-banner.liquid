        <path fill-rule="evenodd" clip-rule="evenodd" d="M25.0374 0C26.8497 0 28.5681 0.946852 29.5149 2.32948L27.7039 4.14171H27.1336C26.7583 3.33929 25.9324 2.84796 25.0374 2.84796C23.9721 2.84796 22.9734 3.72445 22.9141 4.84043C22.8709 5.67988 23.2561 6.20454 23.9511 6.65265C24.6992 7.13534 25.0053 7.33656 26.0213 7.89455C27.1286 8.50315 29.9297 9.6969 29.9297 12.8387C29.9297 15.936 27.341 18.8173 24.0017 18.8173C23.5733 18.8173 22.7968 18.7692 22.2166 18.6358C20.5809 18.2396 19.5884 17.6211 18.5156 16.3582L20.8451 13.9769L21.6475 14.6497C22.0092 14.9336 22.8042 15.5052 23.561 15.6076C25.0991 15.8163 26.1312 14.799 26.3312 13.7954C26.4904 13.0029 26.2892 11.8202 25.0115 11.2079C25.0115 11.2079 22.7079 9.92775 21.6981 9.34384C20.6698 8.74881 19.5761 7.12423 19.5761 5.17744C19.5761 3.72815 20.2402 2.32454 21.3105 1.34683C22.1376 0.588851 23.2721 0 25.0374 0Z" fill="currentColor"/>
