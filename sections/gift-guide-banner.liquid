        <path fill-rule="evenodd" clip-rule="evenodd" d="M9.31791 0V2.74427L8.95497 3.10597H6.21194V18.6358H3.10597V3.10597H0V0.362939L0.362938 0H9.31791Z" fill="currentColor"/>
      </svg>
    </span>

    {%- if section.settings.message != blank -%}
      <span class="gift-banner__message">{{ section.settings.message | escape }}</span>
    {%- endif -%}

    {%- if section.settings.choose_label != blank -%}
      <a href="{{ section.settings.choose_link | default: '#' }}" class="gift-banner__btn gift-banner__choose">
        <span>{{ section.settings.choose_label | escape }}</span>
        {%- render 'gift-banner-arrow' -%}
      </a>
    {%- endif -%}
  </div>

  {%- comment -%} ---------- Hero ---------- {%- endcomment -%}
  <div class="gift-banner__hero">
    {%- comment -%} Desktop line-art illustrations {%- endcomment -%}
    {%- if top_art -%}
      <img class="gift-banner__art gift-banner__art--desktop-top" src="{{ top_art | image_url: width: 1440 }}" srcset="{{ top_art | image_url: width: 1440 }} 1440w, {{ top_art | image_url: width: 2880 }} 2880w" sizes="100vw" width="{{ top_art.width }}" height="{{ top_art.height }}" alt="" loading="lazy">
    {%- else -%}
      <img class="gift-banner__art gift-banner__art--desktop-top" src="{{ 'gift-guide-hero-top.svg' | asset_url }}" width="1440" height="390" alt="" loading="lazy">
    {%- endif -%}

    {%- if bottom_art -%}
      <img class="gift-banner__art gift-banner__art--desktop-bottom" src="{{ bottom_art | image_url: width: 890 }}" srcset="{{ bottom_art | image_url: width: 890 }} 890w, {{ bottom_art | image_url: width: 1780 }} 1780w" sizes="62vw" width="{{ bottom_art.width }}" height="{{ bottom_art.height }}" alt="" loading="lazy">
    {%- else -%}
      <img class="gift-banner__art gift-banner__art--desktop-bottom" src="{{ 'gift-guide-hero-bottom.svg' | asset_url }}" width="890" height="402" alt="" loading="lazy">
    {%- endif -%}

    <div class="gift-banner__content">
      <h1 class="gift-banner__heading">{{ section.settings.heading | escape }}</h1>

      {%- comment -%} richtext already emits its own <p>, so wrap in a div (not <p>) to avoid invalid nested paragraphs {%- endcomment -%}
      {%- if section.settings.description != blank -%}
        <div class="gift-banner__desc gift-banner__desc--desktop">{{ section.settings.description }}</div>
      {%- endif -%}
      {%- if section.settings.description_mobile != blank -%}
        <div class="gift-banner__desc gift-banner__desc--mobile">{{ section.settings.description_mobile }}</div>
      {%- endif -%}

      {%- comment -%} On mobile the CTA is overlaid on the illustration; on desktop it flows below the copy {%- endcomment -%}
      <div class="gift-banner__art-wrap">
        {%- if mobile_art -%}
          <img class="gift-banner__art gift-banner__art--mobile" src="{{ mobile_art | image_url: width: 750 }}" width="{{ mobile_art.width }}" height="{{ mobile_art.height }}" alt="" loading="lazy">
        {%- else -%}
          <img class="gift-banner__art gift-banner__art--mobile" src="{{ 'gift-guide-hero-mobile.png' | asset_url }}" width="375" height="264" alt="" loading="lazy">
        {%- endif -%}

        <div class="gift-banner__cta-wrap">
          <a href="{{ section.settings.shop_link | default: '#' }}" class="gift-banner__btn gift-banner__btn--shop">
            <span>{{ section.settings.shop_label | escape }}</span>
            {%- render 'gift-banner-arrow' -%}
          </a>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ---------- Bottom strip ---------- {%- endcomment -%}
  {%- if section.settings.strip_text != blank or section.settings.strip_text_mobile != blank -%}
    <div class="gift-banner__strip">
      {%- if section.settings.strip_text != blank -%}
        <p class="gift-banner__strip-text gift-banner__strip-text--desktop">{{ section.settings.strip_text | escape }}</p>
      {%- endif -%}
      {%- if section.settings.strip_text_mobile != blank -%}
        <p class="gift-banner__strip-text gift-banner__strip-text--mobile">{{ section.settings.strip_text_mobile | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Gift Guide Banner",
  "tag": "section",
  "class": "section-gift-guide-banner",
  "settings": [
    {
      "type": "header",
      "content": "Top bar"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (for accessibility)",
      "default": "Tisso Vison"
    },
    {
      "type": "checkbox",
      "id": "show_hamburger",
      "label": "Show hamburger icon on mobile",
      "default": true
    },
    {
      "type": "text",
      "id": "message",
      "label": "Top bar message (desktop)",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "choose_label",
      "label": "Button label (desktop)",
      "default": "Choose Gift"
    },
    {
      "type": "url",
      "id": "choose_link",
      "label": "Button link (desktop)"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description (desktop)",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "richtext",
      "id": "description_mobile",
      "label": "Description (mobile)",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.</p>"
    },
    {
      "type": "text",
      "id": "shop_label",
      "label": "Call-to-action label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "shop_link",
      "label": "Call-to-action link"
    },
    {
      "type": "image_picker",
      "id": "hero_image_top",
      "label": "Illustration — top (desktop)",
      "info": "Full-width line art across the top of the hero. Falls back to the bundled asset."
    },
    {
      "type": "image_picker",
      "id": "hero_image_bottom",
      "label": "Illustration — bottom right (desktop)",
      "info": "Line art anchored to the bottom-right. Falls back to the bundled asset."
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Illustration — mobile",
      "info": "Single flattened illustration shown on mobile. Falls back to the bundled asset."
    },
    {
      "type": "header",
      "content": "Bottom strip"
    },
    {
      "type": "text",
      "id": "strip_text",
      "label": "Strip text (desktop)",
      "default": "Sustainable, ethically made clothes in sizes XXS to 6XL"
    },
    {
      "type": "text",
      "id": "strip_text_mobile",
      "label": "Strip text (mobile)",
      "default": "Sustainable, ethically made activewear"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %}
